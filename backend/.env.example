# 教育培训Agent - 环境变量配置

# 应用配置
APP_NAME=教育培训Agent
APP_VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8000

# 数据库配置
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=education_agent

# JWT配置（生产环境请修改为强密钥）
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===========================================
# AI模型配置（只需配置这两项）
# ===========================================

# 模型名称格式：提供商/模型名
# 支持的提供商：
#   - deepseek: deepseek/chat, deepseek/coder, deepseek/reasoner
#   - zhipu: zhipu/glm-4-flash, zhipu/glm-4
#   - openai: openai/gpt-4o-mini, openai/gpt-4o
#   - anthropic: anthropic/claude-sonnet-4-20250514, anthropic/claude-haiku-4-5-20251001
#   - qwen: qwen/qwen-turbo, qwen/qwen-plus

AI_MODEL=deepseek/chat
AI_API_KEY=your-api-key-here

# 可选：自定义API地址（留空使用默认地址）
AI_BASE_URL=

# ===========================================
# Embedding 与向量数据库配置
# ===========================================

# 默认使用本地 sentence-transformers 模型
USE_LOCAL_EMBEDDING=true
LOCAL_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# 如需使用 API Embedding，取消下面注释并填写
# EMBEDDING_API_KEY=your-embedding-api-key
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_BASE_URL=

# ChromaDB 配置（留空使用本地持久化）
# CHROMA_HOST=localhost
# CHROMA_PORT=8001
# CHROMA_PERSIST_DIR=

# 意图分类器配置
INTENT_CLASSIFIER_THRESHOLD=0.7
INTENT_USE_LLM=true

# ReAct 配置（启用后 Agent 会动态调用工具）
USE_REACT=false
REACT_MAX_STEPS=3
REACT_SKILLS=concept_lesson,practice_session

# ===========================================
# 飞书集成配置
# ===========================================

# 飞书 CLI 路径（默认 lark，需确保已安装）
FEISHU_CLI_PATH=lark

# 用户 open_id（ou_xxx），用于个人消息推送和日历提醒
# 在飞书开放平台或通过 CLI 获取：lark auth status
FEISHU_USER_OPEN_ID=

# 旧方式：群机器人 Webhook（可选，兼容旧配置）
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=

# ===========================================

# Redis配置（可选，用于缓存）
REDIS_URL=

# CORS配置（逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
