"""
RAG 问答 API

提供基于知识库的智能问答功能，整合记忆系统。
"""

from typing import Optional, Dict, Any, List
from fastapi import APIRouter, Depends, HTTPException, status
from pydantic import BaseModel, Field
from loguru import logger

from ..core.auth import get_current_user, UserResponse
from ..core.database import get_db, Database
from ..core.config import settings
from ..shared_services import get_memory_manager, get_rag_generator


router = APIRouter(prefix="/api/chat", tags=["RAG 问答"])


# ========== 请求/响应模型 ==========

class ChatRequest(BaseModel):
    """聊天请求"""
    message: str = Field(..., description="用户消息", min_length=1, max_length=2000)
    session_id: Optional[str] = Field(default=None, description="会话 ID（可选）")
    use_memory: bool = Field(default=True, description="是否使用记忆系统")
    use_rag: bool = Field(default=True, description="是否使用 RAG 检索")
    use_web_search: bool = Field(default=False, description="是否使用 Web Search 补充")


class ChatResponse(BaseModel):
    """聊天响应"""
    answer: str = Field(..., description="AI 回答")
    sources: List[Dict[str, Any]] = Field(default_factory=list, description="引用来源")
    session_id: str = Field(..., description="会话 ID")
    metadata: Dict[str, Any] = Field(default_factory=dict, description="元数据")


class HistoryResponse(BaseModel):
    """对话历史响应"""
    session_id: str
    messages: List[Dict[str, Any]]
    total: int


# ========== API 端点 ==========

@router.post("/", response_model=ChatResponse)
async def chat(
    request: ChatRequest,
    current_user: UserResponse = Depends(get_current_user),
):
    """
    RAG 问答

    使用知识库和记忆系统回答用户问题。
    """
    try:
        user_id = current_user.user_id
        generator = get_rag_generator()

        # 获取或创建会话
        memory = get_memory_manager()
        session = memory.recall_memory.get_or_create_session(user_id, request.session_id)
        actual_session_id = session.session_id

        # 生成答案
        result = await generator.generate(
            query=request.message,
            user_id=user_id,
            session_id=actual_session_id,
            use_core_memory=request.use_memory,
            use_recall_memory=request.use_memory,
            use_archival_memory=request.use_memory,
            use_rag=request.use_rag,
            use_web_search=request.use_web_search,
        )

        return ChatResponse(
            answer=result.answer,
            sources=result.sources,
            session_id=actual_session_id,
            metadata=result.metadata,
        )

    except Exception as e:
        logger.error(f"RAG 问答失败: {e}")
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"问答失败: {str(e)}"
        )


@router.get("/history", response_model=HistoryResponse)
async def get_history(
    session_id: Optional[str] = None,
    limit: int = 20,
    current_user: UserResponse = Depends(get_current_user),
):
    """
    获取对话历史

    获取用户的历史对话记录。
    """
    try:
        user_id = current_user.user_id
        memory = get_memory_manager()

        # 获取历史
        history = memory.get_recent_history(
            user_id=user_id,
            session_id=session_id,
            limit=limit,
        )

        # 转换格式
        messages = []
        for turn in history:
            messages.append({
                "id": turn.id,
                "role": turn.role,
                "content": turn.content,
                "timestamp": turn.timestamp,
            })

        return HistoryResponse(
            session_id=session_id or "default",
            messages=messages,
            total=len(messages),
        )

    except Exception as e:
        logger.error(f"获取历史失败: {e}")
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"获取历史失败: {str(e)}"
        )


@router.delete("/history")
async def clear_history(
    session_id: Optional[str] = None,
    current_user: UserResponse = Depends(get_current_user),
):
    """
    清空对话历史

    清空用户的对话历史。
    """
    try:
        user_id = current_user.user_id
        memory = get_memory_manager()

        # 清空历史
        count = memory.recall_memory.clear_user_history(user_id)

        return {"message": f"已清空 {count} 个会话的历史"}

    except Exception as e:
        logger.error(f"清空历史失败: {e}")
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"清空历史失败: {str(e)}"
        )


@router.get("/sessions")
async def get_sessions(
    current_user: UserResponse = Depends(get_current_user),
):
    """
    获取会话列表

    获取用户的所有会话。
    """
    try:
        user_id = current_user.user_id
        memory = get_memory_manager()

        sessions = memory.recall_memory.get_all_sessions(user_id)

        return {
            "sessions": [
                {
                    "session_id": s.session_id,
                    "created_at": s.created_at,
                    "updated_at": s.updated_at,
                    "turn_count": len(s.turns),
                }
                for s in sessions
            ]
        }

    except Exception as e:
        logger.error(f"获取会话列表失败: {e}")
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"获取会话列表失败: {str(e)}"
        )
